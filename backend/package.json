{
  "name": "@giro/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Giro.gtdev API — Hono + TypeScript backend",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "indexing:work-once": "tsx src/commands/processNextIndexingJob.ts",
    "indexing:worker": "tsx src/commands/runIndexingWorker.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:ci",
    "test:node": "NODE_ENV=test node scripts/run-test-suite.mjs node",
    "test:vitest": "NODE_ENV=test node scripts/run-test-suite.mjs vitest",
    "test:ci": "pnpm test:node && pnpm test:vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "openai": "^6.39.1",
    "simple-git": "^3.36.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
