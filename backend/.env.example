# Server
NODE_ENV=development
PORT=8000

# CORS — comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for server-only indexing job persistence. Never expose this key.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Embeddings: "mock" for local dev (free, deterministic), "openai" for real semantic search
EMBEDDINGS_PROVIDER=mock
