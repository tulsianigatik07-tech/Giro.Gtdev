# Server
NODE_ENV=development
PORT=8000

# CORS — comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info

# JWT signing secret (minimum 16 characters)
JWT_SECRET=replace-with-a-long-random-secret

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for server-only indexing job persistence. Never expose this key.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
MODEL_NAME=gpt-4.1-mini

# Embeddings: "mock" for local dev (free, deterministic), "openai" for real semantic search
EMBEDDINGS_PROVIDER=mock

# Absolute in production. Giro creates deterministic hashed checkouts only below this root.
REPOSITORY_STORAGE_ROOT=.storage/repos

# Enable only when this deployment requires an indexing worker to be ready.
INDEXING_WORKER_ENABLED=false
# Optional default for the one-shot indexing worker; CLI --worker-id takes precedence
INDEXING_WORKER_ID=
INDEXING_WORKER_POLL_INTERVAL_MS=1000
INDEXING_WORKER_IDLE_BACKOFF_MS=1000
INDEXING_WORKER_MAX_POLL_INTERVAL_MS=10000
INDEXING_WORKER_STALE_CLAIM_MS=300000
INDEXING_WORKER_HEARTBEAT_MS=15000
INDEXING_WORKER_RETRY_BASE_MS=5000
INDEXING_WORKER_RETRY_MAX_MS=300000
INDEXING_WORKER_MAX_ATTEMPTS=3
INDEXING_WORKER_SHUTDOWN_TIMEOUT_MS=30000

# In-memory semantic retrieval cache
RETRIEVAL_CACHE_TTL_MS=60000
RETRIEVAL_CACHE_MAX_ENTRIES=500
RETRIEVAL_STITCH_LINE_GAP=0
QUERY_EXPANSION_MAX_TERMS=8
QUERY_EXPANSION_SCORE_PENALTY=0.85
RANK_SEMANTIC_WEIGHT=0.35
RANK_KEYWORD_WEIGHT=0.18
RANK_SYMBOL_WEIGHT=0.15
RANK_GRAPH_WEIGHT=0.08
RANK_SUMMARY_WEIGHT=0.07
RANK_ENTRYPOINT_WEIGHT=0.06
RANK_STITCH_BONUS=0.04
RANK_DIVERSITY_BONUS=0.04
RANK_DUPLICATE_PENALTY=0.08
RETRIEVAL_CONFIDENCE_HIGH_THRESHOLD=0.80
RETRIEVAL_CONFIDENCE_MEDIUM_THRESHOLD=0.60
RETRIEVAL_CONFIDENCE_LOW_THRESHOLD=0.35
RETRIEVAL_MIN_CITATION_COVERAGE=0.50
RETRIEVAL_MIN_ANSWERABLE_SCORE=0.35

# Grace period for HTTP and worker shutdown (1000-60000 milliseconds)
SHUTDOWN_TIMEOUT_MS=10000

# Per-identity request limits within the shared window
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_REPOSITORY_CONNECT_MAX_REQUESTS=10
RATE_LIMIT_ASK_GIRO_MAX_REQUESTS=20
RATE_LIMIT_RETRIEVAL_SEARCH_MAX_REQUESTS=60
RATE_LIMIT_INDEXING_MAX_REQUESTS=30

# Request and upstream operation deadlines (milliseconds)
REQUEST_TIMEOUT_MS=30000
AI_REQUEST_TIMEOUT_MS=30000
EMBEDDING_REQUEST_TIMEOUT_MS=30000
DATABASE_REQUEST_TIMEOUT_MS=10000
REPOSITORY_CLONE_TIMEOUT_MS=120000

# Stage-aware retries (retry count excludes the initial attempt)
AI_MAX_RETRIES=2
EMBEDDING_MAX_RETRIES=2
DATABASE_MAX_RETRIES=2
CLONE_MAX_RETRIES=1
AI_RETRY_BASE_MS=200
EMBEDDING_RETRY_BASE_MS=200
DATABASE_RETRY_BASE_MS=100
CLONE_RETRY_BASE_MS=500

# Dependency-scoped circuit breakers
AI_CIRCUIT_MIN_SAMPLES=5
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_WINDOW_MS=60000
AI_CIRCUIT_OPEN_MS=30000
EMBEDDING_CIRCUIT_MIN_SAMPLES=5
EMBEDDING_CIRCUIT_FAILURE_THRESHOLD=5
EMBEDDING_CIRCUIT_WINDOW_MS=60000
EMBEDDING_CIRCUIT_OPEN_MS=30000
DATABASE_CIRCUIT_MIN_SAMPLES=5
DATABASE_CIRCUIT_FAILURE_THRESHOLD=5
DATABASE_CIRCUIT_WINDOW_MS=60000
DATABASE_CIRCUIT_OPEN_MS=15000
CLONE_CIRCUIT_MIN_SAMPLES=3
CLONE_CIRCUIT_FAILURE_THRESHOLD=3
CLONE_CIRCUIT_WINDOW_MS=60000
CLONE_CIRCUIT_OPEN_MS=30000
CIRCUIT_HALF_OPEN_MAX_CALLS=1
