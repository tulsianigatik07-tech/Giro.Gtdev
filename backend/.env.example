# Server
NODE_ENV=development
PORT=8000

# CORS — comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info

# JWT signing secret (minimum 16 characters)
JWT_SECRET=replace-with-a-long-random-secret

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for server-only indexing job persistence. Never expose this key.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
MODEL_NAME=gpt-4.1-mini

# Embeddings: "mock" for local dev (free, deterministic), "openai" for real semantic search
EMBEDDINGS_PROVIDER=mock

# Optional default for the one-shot indexing worker; CLI --worker-id takes precedence
INDEXING_WORKER_ID=

# In-memory semantic retrieval cache
RETRIEVAL_CACHE_TTL_MS=60000
RETRIEVAL_CACHE_MAX_ENTRIES=500
RETRIEVAL_STITCH_LINE_GAP=0
QUERY_EXPANSION_MAX_TERMS=8
QUERY_EXPANSION_SCORE_PENALTY=0.85

# Grace period for HTTP and worker shutdown (1000-60000 milliseconds)
SHUTDOWN_TIMEOUT_MS=10000

# Request and upstream operation deadlines (milliseconds)
REQUEST_TIMEOUT_MS=30000
AI_REQUEST_TIMEOUT_MS=30000
EMBEDDING_REQUEST_TIMEOUT_MS=30000
DATABASE_REQUEST_TIMEOUT_MS=10000
REPOSITORY_CLONE_TIMEOUT_MS=120000

# Stage-aware retries (retry count excludes the initial attempt)
AI_MAX_RETRIES=2
EMBEDDING_MAX_RETRIES=2
DATABASE_MAX_RETRIES=2
CLONE_MAX_RETRIES=1
AI_RETRY_BASE_MS=200
EMBEDDING_RETRY_BASE_MS=200
DATABASE_RETRY_BASE_MS=100
CLONE_RETRY_BASE_MS=500

# Dependency-scoped circuit breakers
AI_CIRCUIT_MIN_SAMPLES=5
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_WINDOW_MS=60000
AI_CIRCUIT_OPEN_MS=30000
EMBEDDING_CIRCUIT_MIN_SAMPLES=5
EMBEDDING_CIRCUIT_FAILURE_THRESHOLD=5
EMBEDDING_CIRCUIT_WINDOW_MS=60000
EMBEDDING_CIRCUIT_OPEN_MS=30000
DATABASE_CIRCUIT_MIN_SAMPLES=5
DATABASE_CIRCUIT_FAILURE_THRESHOLD=5
DATABASE_CIRCUIT_WINDOW_MS=60000
DATABASE_CIRCUIT_OPEN_MS=15000
CLONE_CIRCUIT_MIN_SAMPLES=3
CLONE_CIRCUIT_FAILURE_THRESHOLD=3
CLONE_CIRCUIT_WINDOW_MS=60000
CLONE_CIRCUIT_OPEN_MS=30000
CIRCUIT_HALF_OPEN_MAX_CALLS=1
